{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "npm --prefix ../frontend run build",
    "copy:web": "node ./scripts/sync-web.mjs",
    "sync": "npm run build:web && npm run copy:web && npx cap sync",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "android": "npm run sync && npx cap open android",
    "ios": "npm run sync && npx cap open ios"
  },
  "keywords": [
    "ionic",
    "capacitor",
    "webview"
  ],
  "author": "",
  "license": "MIT",
  "description": "Ionic Capacitor wrapper for frontend Vite build",
  "dependencies": {
    "@capacitor/android": "^7.6.2",
    "@capacitor/cli": "^7.6.2",
    "@capacitor/core": "^7.6.2",
    "@capacitor/ios": "^7.6.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@ionic/react": "^8.8.4",
    "ionicons": "^8.0.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
