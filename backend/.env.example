NODE_ENV=development
PORT=4000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Logs de aplicación (bot / WC / Instagram): info | debug. En debug se incluyen IDs y detalle extra.
LOG_LEVEL=info

DB_HOST=82.197.93.107
DB_PORT=3306
DB_NAME=caradvisor
DB_USER=admin
DB_PASSWORD=change-me

JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=8h

# Token global del motor del bot (mismo valor en bot/.env). Multi-tenant: el owner va en body/query por request.
BACKEND_SERVICE_TOKEN=
# Solo desarrollo single-tenant si falta owner explícito con token global
BOT_DEFAULT_OWNER_USER_ID=
BOT_ENGINE_URL=http://localhost:8000
# Ventana (ms) para agrupar mensajes rápidos del mismo usuario antes de llamar al bot (WA/IG).
BOT_MESSAGE_DEBOUNCE_MS=3000

# Opcional: clave dedicada para cifrar credenciales de integraciones (32+ caracteres recomendado). Si vacío, se deriva de JWT_SECRET.
CREDENTIALS_ENCRYPTION_KEY=

# Firebase Cloud Messaging (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Reemplaza \n por saltos reales al cargar en runtime.
FIREBASE_PRIVATE_KEY=

# WhatsApp Connect: URL base del API upstream y Service JWT global para llamadas salientes.
WC_API_URL=https://api-prueba-whatsapp-connect-aww.vvggha.easypanel.host
WC_SERVICE_JWT=
WC_TIMEOUT_MS=8000
# Detalle WC: WC_WEBHOOK_DEBUG=true y LOG_LEVEL=debug para [wc-webhook:debug]
# WC_WEBHOOK_DEBUG=true

# Instagram / Meta webhooks (misma app Meta; callback único para todos los tenants)
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# META_GRAPH_API_VERSION=v21.0
# META_WEBHOOK_ENABLED=true
# Detalle IG: META_WEBHOOK_DEBUG=true y LOG_LEVEL=debug para [ig-webhook:debug]
# META_WEBHOOK_DEBUG=true

# SMTP (recuperación de contraseña). Si SMTP_HOST está vacío, el código se imprime en consola del backend.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AutoBot <noreply@localhost>
PASSWORD_RESET_CODE_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
